# Copie este arquivo para config/cross.env e ajuste os valores.
# O fluxo principal e totalmente local e nao requer SSH.

# Toolchain ARM hard-float. Em Debian/Ubuntu, o prefixo abaixo corresponde ao
# pacote gcc-arm-linux-gnueabihf.
TARGET_TRIPLE=arm-linux-gnueabihf
CROSS_PREFIX=arm-linux-gnueabihf-

# Deixe vazio para usar o sysroot fornecido pelo cross-compiler. Se o
# compilador nao fornecer um, o fallback sera build/sysroot, importado por
# scripts/cross/sync-sysroot.sh /caminho/para/rootfs.
SYSROOT=

# Cortex-A9 da DE10-Standard, ARMv7 hard-float com NEON.
TARGET_CFLAGS="-O2 -pipe -mcpu=cortex-a9 -mfpu=neon -mfloat-abi=hard"
JOBS=
